[TEMPLATE]
# OmoZoku Environment Variables
# Copy this to .env.local and fill in your values.

# ─── Database ─────────────────────────────────────────────────
# Required for auth (Drizzle ORM with Postgres)
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/omozoku

# ─── Auth ──────────────────────────────────────────────────────
# Required for NextAuth.js JWT signing
# Generate with: openssl rand -hex 32
AUTH_SECRET=change-me-to-a-random-64-char-hex-string

# ─── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Upstash Redis ────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=your-upstash-rest-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# ─── Consumet ─────────────────────────────────────────────────
# Self-host or use a public instance: https://github.com/consumet/consumet.ts
CONSUMET_API_URL=https://your-consumet-instance.com

# ─── Anime Facts API ──────────────────────────────────────────
ANIME_FACTS_API_URL=https://anime-facts-rest-api.herokuapp.com

# ─── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Cache Mode ───────────────────────────────────────────────
# Set to "memory" during local dev (no Redis required), "redis" in production
CACHE_PROVIDER=memory

# ─── Admin ────────────────────────────────────────────────────
# Used to secure the /api/admin/notifications route
ADMIN_NOTIFICATION_SECRET=your-secure-secret
